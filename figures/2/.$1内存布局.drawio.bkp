        <mxCell id="ykJR5Q3p_N5b77mP7SXz-11" value="内核页池&lt;br&gt;0x00204000 开始&lt;br&gt;(KERNEL_PAGE_POOL_START_ADDR)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1">
